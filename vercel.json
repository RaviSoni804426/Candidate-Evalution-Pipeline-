{
  "projectSettings": {
    "sourceFilesOutsideRootDirectory": true
  },
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "env": {
    "VITE_API_BASE_URL": {
      "description": "Backend API URL for the deployed instance",
      "example": "https://your-backend.onrender.com",
      "required": true
    }
  },
  "regions": ["sfo1"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
